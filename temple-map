<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pilgrimage Idea Map</title>
<style>
  :root{
    --bg:#fdf6ec;
    --ink:#3b2a1a;
    --saffron:#e8852b;
    --saffron-deep:#c5651a;
    --done:#2e7d4f;
    --done-bg:#e3f3e8;
    --pending-bg:#fff;
    --line:#e3cba8;
    --shadow:0 6px 18px rgba(120,80,30,.12);
  }
  *{box-sizing:border-box;margin:0;padding:0}
  body{
    font-family:"Segoe UI",system-ui,sans-serif;
    background:
      radial-gradient(circle at 20% 0%, #fff3e0 0%, transparent 45%),
      radial-gradient(circle at 90% 10%, #fdeede 0%, transparent 40%),
      var(--bg);
    color:var(--ink);
    padding:28px 18px 60px;
    min-height:100vh;
  }
  header{text-align:center;max-width:1100px;margin:0 auto 10px}
  h1{
    font-size:2.1rem;letter-spacing:.5px;
    background:linear-gradient(90deg,var(--saffron-deep),var(--saffron));
    -webkit-background-clip:text;background-clip:text;color:transparent;
  }
  .om{font-size:2.4rem;color:var(--saffron-deep);display:block;margin-bottom:4px}
  .sub{color:#7a6450;margin-top:6px;font-size:.95rem}

  .progress-wrap{max-width:520px;margin:18px auto 0}
  .bar{height:14px;background:#f0ddc4;border-radius:20px;overflow:hidden;box-shadow:inset 0 1px 3px rgba(0,0,0,.1)}
  .fill{height:100%;width:0;background:linear-gradient(90deg,var(--done),#46a06a);border-radius:20px;transition:width 1.2s ease}
  .progress-label{text-align:center;margin-top:8px;font-weight:600;color:var(--done)}

  .legend{display:flex;gap:18px;justify-content:center;flex-wrap:wrap;margin:22px auto 30px;font-size:.85rem}
  .legend span{display:inline-flex;align-items:center;gap:6px;color:#6a5440}
  .dot{width:14px;height:14px;border-radius:50%;display:inline-block}
  .dot.d{background:var(--done)}
  .dot.p{background:#fff;border:2px solid var(--saffron)}

  .map{display:grid;grid-template-columns:repeat(2,1fr);gap:24px;max-width:1100px;margin:0 auto}
  @media(max-width:760px){.map{grid-template-columns:1fr}h1{font-size:1.6rem}}

  .group{
    background:#fffaf3;border:1px solid var(--line);border-radius:18px;
    padding:20px 20px 22px;box-shadow:var(--shadow);position:relative;
  }
  .group h2{
    font-size:1.2rem;color:var(--saffron-deep);margin-bottom:4px;
    display:flex;align-items:center;gap:8px;
  }
  .group .count{
    margin-left:auto;font-size:.75rem;font-weight:600;color:#8a7256;
    background:#f3e4cf;padding:2px 10px;border-radius:20px;
  }
  .group .desc{font-size:.82rem;color:#917a63;margin-bottom:14px}

  .items{display:grid;gap:9px}
  .item{
    display:flex;align-items:center;gap:10px;
    background:var(--pending-bg);border:1px solid #f0e2cd;border-radius:11px;
    padding:9px 12px;font-size:.92rem;transition:.2s;
  }
  .item .badge{font-size:.68rem;color:#a88c6e;font-weight:600;min-width:46px}
  .item .name{flex:1;font-weight:500}
  .item .deity{font-size:.74rem;color:#9b8467}
  .item .status{font-size:1.1rem}
  .item.done{background:var(--done-bg);border-color:#bfe2cb}
  .item.done .name{color:var(--done)}
  .item.done .status::after{content:"✓"}
  .item:not(.done) .status::after{content:"○";color:#d9bc95}

  footer{text-align:center;margin-top:36px;color:#9b8467;font-size:.8rem}
</style>
</head>
<body>
<header>
  <span class="om">ॐ</span>
  <h1>Char Dham &amp; Jyotirling — Pilgrimage Idea Map</h1>
  <p class="sub">Tracking my yatra across India's sacred sites</p>
  <div class="progress-wrap">
    <div class="bar"><div class="fill" id="fill"></div></div>
    <div class="progress-label" id="plabel"></div>
  </div>
</header>

<div class="legend">
  <span><i class="dot d"></i> Visited</span>
  <span><i class="dot p"></i> Planned / yet to visit</span>
</div>

<main class="map" id="map"></main>

<footer>Last updated: 30 May 2026 · Sites overlap across categories (e.g. Kedarnath &amp; Badrinath)</footer>

<script>
const DONE = new Set([
  "Grishneshwar","Mahakaleshwar","Bhimashankar","Trimbakeshwar","Nageshwar","Dwarka"
]);

const groups = [
  {
    title:"🛕 Big 4 Dham",
    desc:"The four cardinal abodes established by Adi Shankaracharya",
    items:[
      {badge:"North", name:"Badrinath", deity:"Uttarakhand"},
      {badge:"South", name:"Rameswaram", deity:"Tamil Nadu"},
      {badge:"East",  name:"Jagannath Puri", deity:"Odisha"},
      {badge:"West",  name:"Dwarka", deity:"Gujarat"},
    ]
  },
  {
    title:"🏔️ Chhota Char Dham",
    desc:"The four Himalayan shrines of Uttarakhand",
    items:[
      {badge:"Shiva",  name:"Kedarnath", deity:"Lord Shiva"},
      {badge:"Vishnu", name:"Badrinath", deity:"Lord Vishnu"},
      {badge:"Ganga",  name:"Gangotri", deity:"Goddess Ganga"},
      {badge:"Yamuna", name:"Yamunotri", deity:"Goddess Yamuna"},
    ]
  },
  {
    title:"🔱 12 Jyotirlinga",
    desc:"The twelve radiant lingams of Lord Shiva",
    span:true,
    items:[
      {badge:"01", name:"Somnath", deity:"Gujarat"},
      {badge:"02", name:"Mallikarjuna", deity:"Andhra Pradesh"},
      {badge:"03", name:"Mahakaleshwar", deity:"Madhya Pradesh"},
      {badge:"04", name:"Omkareshwar", deity:"Madhya Pradesh"},
      {badge:"05", name:"Kedarnath", deity:"Uttarakhand"},
      {badge:"06", name:"Bhimashankar", deity:"Maharashtra"},
      {badge:"07", name:"Kashi Vishwanath", deity:"Uttar Pradesh"},
      {badge:"08", name:"Trimbakeshwar", deity:"Maharashtra"},
      {badge:"09", name:"Baidyanath", deity:"Jharkhand"},
      {badge:"10", name:"Nageshwar", deity:"Gujarat"},
      {badge:"11", name:"Ramanathaswamy", deity:"Tamil Nadu"},
      {badge:"12", name:"Grishneshwar", deity:"Maharashtra"},
    ]
  }
];

const map = document.getElementById('map');
let totalSlots = 0, doneSlots = 0;

groups.forEach(g=>{
  const done = g.items.filter(i=>DONE.has(i.name)).length;
  totalSlots += g.items.length; doneSlots += done;

  const card = document.createElement('section');
  card.className = 'group';
  if(g.span) card.style.gridColumn = '1 / -1';
  card.innerHTML = `
    <h2>${g.title}<span class="count">${done}/${g.items.length}</span></h2>
    <p class="desc">${g.desc}</p>
    <div class="items">
      ${g.items.map(i=>`
        <div class="item ${DONE.has(i.name)?'done':''}">
          <span class="badge">${i.badge}</span>
          <span class="name">${i.name}</span>
          <span class="deity">${i.deity}</span>
          <span class="status"></span>
        </div>`).join('')}
    </div>`;
  if(g.span){
    card.querySelector('.items').style.gridTemplateColumns='repeat(auto-fill,minmax(220px,1fr))';
  }
  map.appendChild(card);
});

// unique-site progress (count distinct visited sites vs distinct total)
const allNames = new Set();
groups.forEach(g=>g.items.forEach(i=>allNames.add(i.name)));
const uniqDone = [...allNames].filter(n=>DONE.has(n)).length;
const pct = Math.round(uniqDone/allNames.size*100);

setTimeout(()=>{document.getElementById('fill').style.width = pct+'%';},200);
document.getElementById('plabel').textContent =
  `${uniqDone} of ${allNames.size} unique sites visited · ${pct}%`;
</script>
</body>
</html>
